# Copy this file to .env and update as needed

# Use GPU acceleration (set to true if you have NVIDIA GPU with CUDA)
USE_GPU=false

# Whisper model size: tiny, base, small, medium, large
WHISPER_MODEL=base

# Summarization model: facebook/bart-large-cnn or t5-base
SUMMARIZATION_MODEL=facebook/bart-large-cnn

# TTS model (Coqui TTS)
TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# Storage paths (relative to project root)
STORAGE_DIR=../storage
UPLOAD_DIR=../storage/uploads
FRAMES_DIR=../storage/frames
AUDIO_DIR=../storage/audio
TTS_DIR=../storage/tts
EXPORTS_DIR=../storage/exports

# Database
DATABASE_URL=sqlite+aiosqlite:///./videosummarizer.db

# Server
HOST=0.0.0.0
PORT=8000

# CORS allowed origins (frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
